    <elementParameter field="CHECK" name="configuration.dataSet.dataStore.shareConnection" value="false" show="false"/>
    <elementParameter field="TACOKIT_VALUE_SELECTION" name="configuration.dataSet.tableName" value="&quot;EDI_PLANNING_TRAITEMENT&quot;"/>
    <elementParameter field="CHECK" name="configuration.dataSet.manualQuery" value="true"/>
    <elementParameter field="TEXT" name="configuration.dataSet.condition" value="&quot;&quot;" show="false"/>
    <elementParameter field="MEMO_SQL" name="configuration.dataSet.sqlQuery" value="&quot;&#xD;&#xA;SELECT&#xA;  pf.CODE_ENTITE,&#xA;  pf.CODE_PARTENAIRE,&#xA;  pf.CODE_TYPE_FLUX,&#xA;  pf.SENS_FLUX,&#xA;&#xA;  pf.CODE_CONNEXION_SOURCE,&#xA;  pf.CODE_CONNEXION_CIBLE,&#xA;&#xA;  pf.CHEMIN_SOURCE,&#xA; &#xD;&#xA;pf.MASQUE_FICHIER_SOURCE,&#xD;&#xA;pf.CHEMIN_CIBLE,&#xA;  pf.CHEMIN_ARCHIVE,&#xA;  pf.CHEMIN_ERREUR,&#xA;&#xA;  pf.DUREE_RETENTION_ANNEES,&#xA;  pf.EMAIL_CONTACT,&#xA;&#xA;  c_src.CODE_CANAL    AS CANAL_SOURCE,&#xA;  c_src.HOST          AS HOST_SOURCE,&#xA;  c_src.PORT          AS PORT_SOURCE,&#xA;  c_src.UTILISATEUR   AS USER_SOURCE,&#xA;  c_src.MOT_DE_PASSE  AS PASSWORD_SOURCE,&#xA;  c_src.CHEMIN_RACINE AS RACINE_SOURCE,&#xA;&#xA;  c_cib.CODE_CANAL    AS CANAL_CIBLE,&#xA;  c_cib.HOST          AS HOST_CIBLE,&#xA;  c_cib.PORT          AS PORT_CIBLE,&#xA;  c_cib.UTILISATEUR   AS USER_CIBLE,&#xA;  c_cib.MOT_DE_PASSE  AS PASSWORD_CIBLE,&#xA;  c_cib.CHEMIN_RACINE AS RACINE_CIBLE,&#xD;&#xA;&#x9;pf.DELETE_SRC_FILES AS DELETE_SRC_FILES&#xA;&#xA;FROM DB_EDI_SEMIN.EDI_SEMIN_CONFIG_PARAMS.EDI_PARAMETRAGE_FLUX pf&#xA;&#xA;JOIN DB_EDI_SEMIN.EDI_SEMIN_CONFIG_PARAMS.EDI_CONNEXION c_src&#xA;  ON c_src.CODE_CONNEXION = pf.CODE_CONNEXION_SOURCE&#xA; AND c_src.IS_ACTIF = TRUE&#xA;&#xA;JOIN DB_EDI_SEMIN.EDI_SEMIN_CONFIG_PARAMS.EDI_CONNEXION c_cib&#xA;  ON c_cib.CODE_CONNEXION = pf.CODE_CONNEXION_CIBLE&#xA; AND c_cib.IS_ACTIF = TRUE&#xA;&#xA;JOIN DB_EDI_SEMIN.EDI_SEMIN_CONFIG_PARAMS.EDI_PARTENAIRE p&#xA;  ON p.CODE_PARTENAIRE = pf.CODE_PARTENAIRE&#xA; AND p.IS_ACTIF = TRUE&#xA;&#xA;JOIN DB_EDI_SEMIN.EDI_SEMIN_CONFIG_PARAMS.EDI_ENTITE_SEMIN e&#xA;  ON e.CODE_ENTITE = pf.CODE_ENTITE&#xA; AND e.IS_ACTIF = TRUE&#xA;&#xA;WHERE pf.IS_ACTIF = TRUE&#xA;  AND pf.SENS_FLUX = 'SORTANT';&#xA;&#xD;&#xA;&quot;"/>
    <elementParameter field="CHECK" name="configuration.dataSet.dataStore.autoCommit" value="true" show="false"/>
    <elementParameter field="TEXT" name="configuration.dataSet.dataStore.jdbcParameters" value="&quot;&quot;" show="false"/>
