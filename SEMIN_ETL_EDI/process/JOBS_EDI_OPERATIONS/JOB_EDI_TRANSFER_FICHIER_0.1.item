    <elementParameter field="MEMO_EDITOR_JAVA" name="CODE" value="System.out.println(&quot;p_CANAL_SOURCE             = &quot; + context.p_CANAL_SOURCE);&#xD;&#xA;System.out.println(&quot;p_CANAL_CIBLE              = &quot; + context.p_CANAL_CIBLE);&#xD;&#xA;System.out.println(&quot;p_HOST_SOURCE             = &quot; + context.p_HOST_SOURCE);&#xD;&#xA;System.out.println(&quot;p_USER_SOURCE             = &quot; + context.p_USER_SOURCE);&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;log.warn(&quot;p_CANAL_SOURCE = &quot; + context.p_CANAL_SOURCE);&#xD;&#xA;log.warn(&quot;p_CANAL_CIBLE  = &quot; + context.p_CANAL_CIBLE);&#xD;&#xA;log.warn(&quot;p_HOST_SOURCE  = &quot; + context.p_HOST_SOURCE);&#xD;&#xA;log.warn(&quot;p_USER_SOURCE  = &quot; + context.p_USER_SOURCE);&#xD;&#xA;&#xD;&#xA;java.io.File dir = new java.io.File(context.p_CHEMIN_SOURCE);&#xD;&#xA;log.warn(&quot;DIR = &quot; + context.p_CHEMIN_SOURCE);&#xD;&#xA;log.warn(&quot;Exists = &quot; + dir.exists());&#xD;&#xA;log.warn(&quot;IsDir  = &quot; + dir.isDirectory());&#xD;&#xA;&#xD;&#xA;if (dir.exists() &amp;&amp; dir.isDirectory()) {&#xD;&#xA;  java.io.File[] files = dir.listFiles();&#xD;&#xA;  log.warn(&quot;listFiles() count = &quot; + (files == null ? &quot;null&quot; : files.length));&#xD;&#xA;  if (files != null) {&#xD;&#xA;    for (java.io.File f : files) {&#xD;&#xA;      log.warn(&quot;FILE FOUND: &quot; + f.getName());&#xD;&#xA;    }&#xD;&#xA;  }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;"/>
    <elementParameter field="MEMO_EDITOR_IMPORT" name="IMPORT" value="//import java.util.List;"/>
    <elementParameter field="TEXT" name="CONNECTION_FORMAT" value="row"/>
    <metadata connector="FLOW" name="tJava_1"/>
  </node>
