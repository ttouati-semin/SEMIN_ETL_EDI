    <elementParameter field="MEMO_EDITOR_JAVA" name="CODE" value="int lastId = (Integer) globalMap.get(&quot;last_id&quot;);&#xD;&#xA;int pageSize = (Integer) globalMap.get(&quot;page_size&quot;);&#xD;&#xA;&#xD;&#xA;System.out.println(&quot;lastId : &quot; + lastId + &quot; pageSize : &quot; + pageSize);&#xD;&#xA;&#xD;&#xA;String xml =&#xD;&#xA;&quot;&lt;?xml version=\&quot;1.0\&quot;?>\n&quot; +&#xD;&#xA;&quot;&lt;methodCall>\n&quot; +&#xD;&#xA;&quot;  &lt;methodName>execute_kw&lt;/methodName>\n&quot; +&#xD;&#xA;&quot;  &lt;params>\n&quot; +&#xD;&#xA;&#xD;&#xA;&quot;    &lt;param>&lt;value>&lt;string>wondertex&lt;/string>&lt;/value>&lt;/param>\n&quot; +&#xD;&#xA;&quot;    &lt;param>&lt;value>&lt;int>2&lt;/int>&lt;/value>&lt;/param>\n&quot; +&#xD;&#xA;&quot;    &lt;param>&lt;value>&lt;string>&quot; + context.odoo_api_key + &quot;&lt;/string>&lt;/value>&lt;/param>\n&quot; +&#xD;&#xA;&#xD;&#xA;&quot;    &lt;param>&lt;value>&lt;string>product.category&lt;/string>&lt;/value>&lt;/param>\n&quot; +&#xD;&#xA;&quot;    &lt;param>&lt;value>&lt;string>search_read&lt;/string>&lt;/value>&lt;/param>\n&quot; +&#xD;&#xA;&#xD;&#xA;&quot;    &lt;!-- args : domain -->\n&quot; +&#xD;&#xA;&quot;    &lt;param>\n&quot; +&#xD;&#xA;&quot;      &lt;value>\n&quot; +&#xD;&#xA;&quot;        &lt;array>\n&quot; +&#xD;&#xA;&quot;          &lt;data>\n&quot; +&#xD;&#xA;&quot;            &lt;value>\n&quot; +&#xD;&#xA;&quot;              &lt;array>\n&quot; +&#xD;&#xA;&quot;                &lt;data>\n&quot; +&#xD;&#xA;&quot;                  &lt;value>\n&quot; +&#xD;&#xA;&quot;                    &lt;array>\n&quot; +&#xD;&#xA;&quot;                      &lt;data>\n&quot; +&#xD;&#xA;&quot;                        &lt;value>&lt;string>id&lt;/string>&lt;/value>\n&quot; +&#xD;&#xA;&quot;                        &lt;value>&lt;string>&amp;gt;&lt;/string>&lt;/value>\n&quot; +&#xD;&#xA;&quot;                        &lt;value>&lt;int>&quot; + lastId + &quot;&lt;/int>&lt;/value>\n&quot; +&#xD;&#xA;&quot;                      &lt;/data>\n&quot; +&#xD;&#xA;&quot;                    &lt;/array>\n&quot; +&#xD;&#xA;&quot;                  &lt;/value>\n&quot; +&#xD;&#xA;&quot;                &lt;/data>\n&quot; +&#xD;&#xA;&quot;              &lt;/array>\n&quot; +&#xD;&#xA;&quot;            &lt;/value>\n&quot; +&#xD;&#xA;&quot;          &lt;/data>\n&quot; +&#xD;&#xA;&quot;        &lt;/array>\n&quot; +&#xD;&#xA;&quot;      &lt;/value>\n&quot; +&#xD;&#xA;&quot;    &lt;/param>\n&quot; +&#xD;&#xA;&#xD;&#xA;&quot;    &lt;!-- kwargs -->\n&quot; +&#xD;&#xA;&quot;    &lt;param>\n&quot; +&#xD;&#xA;&quot;      &lt;value>\n&quot; +&#xD;&#xA;&quot;        &lt;struct>\n&quot; +&#xD;&#xA;&#xD;&#xA;&quot;          &lt;member>\n&quot; +&#xD;&#xA;&quot;            &lt;name>limit&lt;/name>\n&quot; +&#xD;&#xA;&quot;            &lt;value>&lt;int>&quot; + pageSize + &quot;&lt;/int>&lt;/value>\n&quot; +&#xD;&#xA;&quot;          &lt;/member>\n&quot; +&#xD;&#xA;&#xD;&#xA;&quot;          &lt;member>\n&quot; +&#xD;&#xA;&quot;            &lt;name>order&lt;/name>\n&quot; +&#xD;&#xA;&quot;            &lt;value>&lt;string>id asc&lt;/string>&lt;/value>\n&quot; +&#xD;&#xA;&quot;          &lt;/member>\n&quot; +&#xD;&#xA;&#xD;&#xA;&quot;          &lt;member>\n&quot; +&#xD;&#xA;&quot;            &lt;name>fields&lt;/name>\n&quot; +&#xD;&#xA;&quot;            &lt;value>\n&quot; +&#xD;&#xA;&quot;              &lt;array>\n&quot; +&#xD;&#xA;&quot;                &lt;data>\n&quot; +&#xD;&#xA;&quot;                  &lt;value>&lt;string>id&lt;/string>&lt;/value>\n&quot; +&#xD;&#xA;&quot;                  &lt;value>&lt;string>name&lt;/string>&lt;/value>\n&quot; +&#xD;&#xA;&quot;                  &lt;value>&lt;string>complete_name&lt;/string>&lt;/value>\n&quot; +&#xD;&#xA;&quot;                  &lt;value>&lt;string>display_name&lt;/string>&lt;/value>\n&quot; +&#xD;&#xA;&quot;                  &lt;value>&lt;string>parent_id&lt;/string>&lt;/value>\n&quot; +&#xD;&#xA;&quot;                  &lt;value>&lt;string>parent_path&lt;/