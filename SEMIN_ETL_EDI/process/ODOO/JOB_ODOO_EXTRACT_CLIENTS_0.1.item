    <elementParameter field="MEMO_EDITOR_JAVA" name="CODE" value="Integer maxId = input_row.max_id;&#xD;&#xA;&#xD;&#xA;Object oLast = globalMap.get(&quot;last_id&quot;);&#xD;&#xA;Integer lastId = (oLast == null) ? null : ((Number) oLast).intValue();  // gère Integer/Long/BigDecimal&#xD;&#xA;&#xD;&#xA;System.out.println(&quot;DEBUG types: maxId=&quot; + maxId + &quot; (&quot; + (maxId==null?&quot;null&quot;:maxId.getClass().getName())&#xD;&#xA;        + &quot;), lastId=&quot; + lastId + &quot; (&quot; + (oLast==null?&quot;null&quot;:oLast.getClass().getName()) + &quot;)&quot;);&#xD;&#xA;&#xD;&#xA;if (maxId == null || java.util.Objects.equals(maxId, lastId)) {&#xD;&#xA;    System.out.println(&quot;STOP: maxId null or unchanged -> maxId=&quot; + maxId + &quot;, lastId=&quot; + lastId);&#xD;&#xA;    globalMap.put(&quot;has_data&quot;, false);&#xD;&#xA;} else {&#xD;&#xA;    System.out.println(&quot;CONTINUE: new maxId=&quot; + maxId + &quot; (old lastId=&quot; + lastId + &quot;)&quot;);&#xD;&#xA;    globalMap.put(&quot;last_id&quot;, maxId);&#xD;&#xA;    globalMap.put(&quot;has_data&quot;, true);&#xD;&#xA;}"/>
    <elementParameter field="MEMO_EDITOR_IMPORT" name="IMPORT" value="//import java.util.List;"/>
    <elementParameter field="TEXT" name="CONNECTION_FORMAT" value="row"/>
    <metadata connector="FLOW" label="MAX_ID" name="tJavaRow_1">
      <column comment="" key="false" length="-1" name="max_id" nullable="true" pattern="" precision="-1" sourceType="" type="id_Integer" originalLength="-1" usefulColumn="true"/>
