  <node componentName="tMSSqlInput" componentVersion="0.102" offsetLabelX="0" offsetLabelY="0" posX="240" posY="920">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tDBInput_3" show="false"/>
    <elementParameter field="CHECK" name="USE_EXISTING_CONNECTION" value="true"/>
    <elementParameter field="COMPONENT_LIST" name="CONNECTION" value="tDBConnection_1"/>
    <elementParameter field="TEXT" name="HOST" value="&quot;ULYSSE\\NAVISION&quot;" show="false"/>
    <elementParameter field="CLOSED_LIST" name="DRIVER" value="MSSQL_PROP" show="false"/>
    <elementParameter field="TEXT" name="TYPE" value="MSSQL" show="false"/>
    <elementParameter field="TEXT" name="PORT" value="&quot;&quot;" show="false"/>
    <elementParameter field="TEXT" name="DB_SCHEMA" value="&quot;dbo&quot;" show="false"/>
    <elementParameter field="TEXT" name="DBNAME" value="&quot;SEMIN&quot;" show="false"/>
    <elementParameter field="TEXT" name="USER" value="&quot;SQLTalend&quot;" show="false"/>
    <elementParameter field="PASSWORD" name="PASS" value="enc:system.encryption.key.v1:4tsNLBFTJGjiE+ixQEDNeLNAuYAZ8TGemOuUIQs77z7X02+qUkaEF/ub" show="false"/>
    <elementParameter field="DBTABLE" name="TABLE" value="&quot;&quot;"/>
    <elementParameter field="QUERYSTORE_TYPE" name="QUERYSTORE" value="&quot;&quot;"/>
    <elementParameter field="TECHNICAL" name="QUERYSTORE:REPOSITORY_QUERYSTORE_TYPE" value="" show="false"/>
    <elementParameter field="TECHNICAL" name="QUERYSTORE:QUERYSTORE_TYPE" value="BUILT_IN"/>
    <elementParameter field="GUESS_SCHEMA" name="GUESS_SCHEMA" value="&quot;&quot;"/>
    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;select &#xD;&#xA;    [Customer No_] AS [Nom du client],  &#xD;&#xA;&#xD;&#xA;    [Document No_] AS [Numéro unique de facture],  &#xD;&#xA;&#xD;&#xA;    -- que faire pour garantir l'unicité ? &#xD;&#xA;    -- entre les différentes entités hébergées sous Navision, la codification est similaire &#xD;&#xA;    -- mais chaque entité a son compteur si bien qu'on peut avoir des doublons &#xD;&#xA;&#xD;&#xA;    -- => Ajouter l'identifiant société ? Ajouter une colonne : Code entité &#xD;&#xA;&#xD;&#xA;    FORMAT([Posting Date], 'dd-MM-yyyy') AS [Date de facturation], &#xD;&#xA;&#xD;&#xA;    FORMAT([Due Date],     'dd-MM-yyyy') AS [Date d''échéance], &#xD;&#xA;&#xD;&#xA;    CAST([Sales (LCY)] AS DECIMAL(18,2)) AS [Montant TTC], &#xD;&#xA;&#xD;&#xA;    'EUR' AS [Devise], &#xD;&#xA;&#xD;&#xA;    [Source Code] AS [Code journal], &#xD;&#xA;&#xD;&#xA;    COALESCE(NULLIF([Payment Method], ''), '\&quot;\&quot;') AS [Méthode de paiement], &#xD;&#xA;&#xD;&#xA;    COALESCE(NULLIF([Description], ''), '\&quot;\&quot;') AS [Libellé de l''écriture], &#xD;&#xA;&#xD;&#xA;    COALESCE(NULLIF([Last Factor Cession No_], ''), '\&quot;\&quot;') AS [Identifiant factoring], &#xD;&#xA;&#xD;&#xA;    COALESCE( &#xD;&#xA;        FORMAT([Original Currency Factor], '0.########'), &#xD;&#xA;&#x9;'\&quot;\&quot;') AS [Fonds de garantie], &#xD;&#xA;&#xD;&#xA;    cast([Sell-to Customer No_] AS varchar(50))[code tiers], &#xD;&#xA;&#x9;&#xD;&#xA;&#x9;COALESCE(CAST([Entry No_] AS varchar(20)), '\&quot;\&quot;') AS [ID technique facture] &#xD;&#xA;&#xD;&#xA; from &quot; + ((String)globalMap.get(&quot;SQLServer_Table_SEMIN_ESPAGNE&quot;))&#xD;&#xA;+ &quot;&#xD;&#xA;WHERE [Open] = 1 -- ouvert donc non soldé &#xD;&#xA;  AND [Document Type] IN (2, 3); -- facture et avoir &#xD;&#xA;&quot;"/>
    <elementParameter field="LABEL" name="NOTE" value="This option only applies when deploying and running in the Talend Runtime" show="false"/>
    <elementParameter field="CHECK" name="SPECIFY_DATASOURCE_ALIAS" value="false" show="false"/>
    <elementParameter field="TEXT" name="DATASOURCE_ALIAS" value="&quot;&quot;" show="false"/>
    <elementParameter field="MAPPING_TYPE" name="MAPPING" value="id_MSSQL" show="false"/>
    <elementParameter field="TEXT" name="PROPERTIES" value="&quot;noDatetimeStringSync=true&quot;" show="false"/>
    <elementParameter field="CHECK" name="ACTIVE_DIR_AUTH" value="false" show="false"/>
