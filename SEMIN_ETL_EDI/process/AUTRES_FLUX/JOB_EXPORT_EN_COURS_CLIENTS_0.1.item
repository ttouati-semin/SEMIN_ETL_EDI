    <elementParameter field="GUESS_SCHEMA" name="GUESS_SCHEMA" value="&quot;&quot;"/>
    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;&#xD;&#xA;SELECT &#xD;&#xA;&#xD;&#xA;      [JO_Num] AS [Code journal] &#xD;&#xA;&#xD;&#xA;    , [CT_Num] AS [Nom du client] &#xD;&#xA;&#xD;&#xA;    , [EC_Piece] AS [Numéro unique de facture] &#xD;&#xA;&#xD;&#xA;    , FORMAT([JM_Date], 'dd-MM-yyyy') AS [Date de facturation] &#xD;&#xA;&#xD;&#xA;    , [EC_Intitule] AS [Libellé de l'écriture] &#xD;&#xA;&#xD;&#xA;    , [N_Devise] AS [Devise] &#xD;&#xA;&#xD;&#xA;    , [EC_Montant] AS [Montant TTC] &#xD;&#xA;&#xD;&#xA;    , [N_Reglement] AS [Méthode de règlement] &#xD;&#xA;&#xD;&#xA;    , [EC_Lettre] AS [Code lettrage] &#xD;&#xA;&#xD;&#xA;    , FORMAT([EC_Echeance], 'dd-MM-yyyy') AS [Date échéance] &#xD;&#xA;&#xD;&#xA;, [EC_No] as 'Identifiant technique facture' &#xD;&#xA;&#xD;&#xA; &#xD;&#xA;&#xD;&#xA;FROM [F_ECRITUREC] &#xD;&#xA;&#xD;&#xA;WHERE [JO_Num] IN (02,03,04,05,06,07,08,09,10,12,14,17,18,19,30,99) &#xD;&#xA;&#xD;&#xA;  AND [CG_Num] NOT LIKE '40%'; &#xD;&#xA;&quot;"/>
    <elementParameter field="LABEL" name="NOTE" value="This option only applies when deploying and running in the Talend Runtime" show="false"/>
    <elementParameter field="CHECK" name="SPECIFY_DATASOURCE_ALIAS" value="false" show="false"/>
